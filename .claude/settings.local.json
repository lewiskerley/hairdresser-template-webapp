{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(Start-Process npm *)",
      "Bash(Start-Sleep -Seconds 3)",
      "Bash(Invoke-WebRequest -Uri \"http://localhost:5173\" -UseBasicParsing -TimeoutSec 5)",
      "Bash(Select-Object -ExpandProperty StatusCode)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173)",
      "Bash(node -e \"require\\('playwright'\\)\")",
      "Bash(npx playwright *)"
    ]
  }
}
